# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_USER=cveuser
DB_PASSWORD=cvepass
DB_NAME=cvetracker
DB_SSLMODE=prefer # options: disable, prefer, require, verify-ca, verify-full

# Redis Configuration
REDIS_URL=redis:6379

# Session and Security
SESSION_KEY=change-me-to-a-long-random-string
CSRF_KEY=MOCK_CSRF_KEY_32_BYTES_FOR_TEST! # Must be 32 bytes
SECURE_COOKIE=false # Set to true in production with HTTPS (affects session store)

# Administrator Account (REQUIRED)
# These values are used to seed the initial admin user.
# TOTP is mandatory for the admin account.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-something-secure
ADMIN_TOTP_SECRET=YOUR_TOTP_SECRET_BASE32 # Generate a secure base32 secret

# SMTP Configuration (Optional but recommended for alerts)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=password
SMTP_MAILFROM=alerts@example.com # Sender address for emails

# Application URL
BASE_URL=http://localhost:8080

# NVD API Configuration
# Get a free API key at https://nvd.nist.gov/developers/request-an-api-key
# Without a key, rate limits are strict (5 requests per 30s).
# With a key, rate limits are 50 requests per 30s.
# NVD_API_KEY=your-api-key-here
